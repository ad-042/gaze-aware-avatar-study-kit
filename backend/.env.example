# Backend environment configuration for study-v1
# Copy to .env and adjust values.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# --- OpenAI Realtime ---
# Both OPENAI_API_KEY and OPENAI_REALTIME_ENABLED must be set for Realtime to work.
OPENAI_API_KEY=
OPENAI_REALTIME_ENABLED=False
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=alloy

# --- Tobii (optional, Windows only) ---
TOBII_ENABLED=False
TOBIISTREAM_PATH=
TOBII_ZMQ_ENDPOINT=tcp://127.0.0.1:5556
